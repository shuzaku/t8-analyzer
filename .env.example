# Copy to .env and fill in values (do not commit .env)

# Roboflow (when using --roboflow)
# ROBOFLOW_API_KEY=your_roboflow_api_key

# MongoDB (when MONGO_URI is set, each analysis is saved after export)
# MONGO_URI=mongodb://localhost:27017
# MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/?retryWrites=true&w=majority
# MONGO_DATABASE=tekken8_analyzer
# MONGO_COLLECTION=analyses
# Match lookup (before insert): find MatchId by video URL
# MONGO_MATCHES_COLLECTION=matches
# MONGO_VIDEO_URL_FIELD=videoUrl

# YouTube / yt-dlp (when YouTube asks to sign in or blocks as a bot)
# YTDLP_COOKIE_FILE=C:/path/to/youtube_cookies.txt
# YTDLP_COOKIES_FROM_BROWSER=chrome
# YouTube n-challenge (install Deno 2+ or Node 20+; pip install "yt-dlp[default]")
# YTDLP_JS_RUNTIMES=node
# YTDLP_REMOTE_COMPONENTS=ejs:github
